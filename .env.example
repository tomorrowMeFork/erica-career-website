# HY-CDP credentials for local authenticated collection.
# Copy this file to .env and fill in real values locally.
# Never commit .env or any file containing real credentials.
CDP_USERNAME=
CDP_PASSWORD=

# Optional Playwright runtime controls for local collectors.
# Set to false if you need to watch the login/navigation flow.
PLAYWRIGHT_HEADLESS=true

# Optional conservative collection limits for source discovery runs.
COLLECT_MAX_PAGES=5
COLLECT_DELAY_MS=1500
